    glBindVertexArray(cubeVAO);
    glDrawArrays(GL_TRIANGLES, 0, 36);

    // Walls
    shader.setVec3("objectColor", 0.85f, 0.85f, 0.88f);

    // Back wall
    model = glm::mat4(1.0f);
    model = glm::translate(model, glm::vec3(0.0f, 5.0f, -15.0f));
    model = glm::scale(model, glm::vec3(40.0f, 10.0f, 0.5f));
    shader.setMat4("model", model);
    glDrawArrays(GL_TRIANGLES, 0, 36);

    // Left wall
    model = glm::mat4(1.0f);
    model = glm::translate(model, glm::vec3(-20.0f, 5.0f, 0.0f));
    model = glm::scale(model, glm::vec3(0.5f, 10.0f, 30.0f));
    shader.setMat4("model", model);
    glDrawArrays(GL_TRIANGLES, 0, 36);

    // Right wall
    model = glm::mat4(1.0f);
    model = glm::translate(model, glm::vec3(20.0f, 5.0f, 0.0f));
    model = glm::scale(model, glm::vec3(0.5f, 10.0f, 30.0f));
    shader.setMat4("model", model);
    glDrawArrays(GL_TRIANGLES, 0, 36);

    // Ceiling
    shader.setVec3("objectColor", 0.9f, 0.9f, 0.92f);
    model = glm::mat4(1.0f);
    model = glm::translate(model, glm::vec3(0.0f, 10.0f, 0.0f));
    model = glm::scale(model, glm::vec3(40.0f, 0.2f, 30.0f));
    shader.setMat4("model", model);
    glDrawArrays(GL_TRIANGLES, 0, 36);

    // Windows on left wall
    shader.setVec3("objectColor", 0.6f, 0.8f, 0.9f);
    for (int i = 0; i < 3; i++) {
        model = glm::mat4(1.0f);
        model = glm::translate(model, glm::vec3(-19.8f, 6.0f, -8.0f + i * 8.0f));
        model = glm::rotate(model, glm::radians(windowAngle), glm::vec3(0.0f, 1.0f, 0.0f));
        model = glm::scale(model, glm::vec3(0.1f, 3.0f, 2.5f));
        shader.setMat4("model", model);
        glDrawArrays(GL_TRIANGLES, 0, 36);
    }

    // Door
    shader.setVec3("objectColor", 0.6f, 0.4f, 0.3f);
    model = glm::mat4(1.0f);
    model = glm::translate(model, glm::vec3(10.0f, 3.0f, 14.8f));
    model = glm::rotate(model, glm::radians(doorAngle), glm::vec3(0.0f, 1.0f, 0.0f));
    model = glm::scale(model, glm::vec3(2.0f, 6.0f, 0.2f));
    shader.setMat4("model", model);
    glDrawArrays(GL_TRIANGLES, 0, 36);

    // Ceiling Fan
    shader.setVec3("objectColor", 0.3f, 0.3f, 0.3f);
    model = glm::mat4(1.0f);
    model = glm::translate(model, glm::vec3(0.0f, 9.5f, 0.0f));
    model = glm::scale(model, glm::vec3(0.3f, 0.5f, 0.3f));
    shader.setMat4("model", model);
    glDrawArrays(GL_TRIANGLES, 0, 36);

    // Fan blades
    shader.setVec3("objectColor", 0.7f, 0.7f, 0.7f);
    for (int i = 0; i < 4; i++) {
        model = glm::mat4(1.0f);
        model = glm::translate(model, glm::vec3(0.0f, 9.3f, 0.0f));
        model = glm::rotate(model, glm::radians(fanRotation + i * 90.0f), glm::vec3(0.0f, 1.0f, 0.0f));
        model = glm::translate(model, glm::vec3(1.5f, 0.0f, 0.0f));
        model = glm::scale(model, glm::vec3(3.0f, 0.1f, 0.5f));
