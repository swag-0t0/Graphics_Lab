            model = glm::translate(model, glm::vec3(0.0f, j * 0.3f - 0.15f, 0.0f));
            model = glm::scale(model, glm::vec3(0.3f, 1.2f, 1.2f));
            shader.setMat4("model", model);
            glDrawArrays(GL_TRIANGLE_STRIP, 0, 66);
        }
    }

    // Dumbbells
    shader.setVec3("objectColor", 0.3f, 0.3f, 0.35f);
    for (int i = 0; i < 4; i++) {
        model = glm::mat4(1.0f);
        model = glm::translate(model, glm::vec3(-5.0f + i * 1.5f, 0.3f, 5.0f));
        model = glm::rotate(model, glm::radians(90.0f), glm::vec3(0.0f, 0.0f, 1.0f));
        model = glm::scale(model, glm::vec3(0.08f, 1.0f, 0.08f));
        shader.setMat4("model", model);
        glDrawArrays(GL_TRIANGLE_STRIP, 0, 66);

        shader.setVec3("objectColor", 0.1f, 0.1f, 0.1f);
        for (int j = 0; j < 2; j++) {
            model = glm::mat4(1.0f);
            model = glm::translate(model, glm::vec3(-5.0f + i * 1.5f, 0.3f, 5.0f));
            model = glm::rotate(model, glm::radians(90.0f), glm::vec3(0.0f, 0.0f, 1.0f));
            model = glm::translate(model, glm::vec3(0.0f, (j - 0.5f) * 0.7f, 0.0f));
            model = glm::scale(model, glm::vec3(0.2f, 0.3f, 0.3f));
            shader.setMat4("model", model);
            glDrawArrays(GL_TRIANGLE_STRIP, 0, 66);
        }
        shader.setVec3("objectColor", 0.3f, 0.3f, 0.35f);
    }

    // Exercise bike
    shader.setVec3("objectColor", 0.8f, 0.1f, 0.1f);
    glBindVertexArray(cubeVAO);
    model = glm::mat4(1.0f);
    model = glm::translate(model, glm::vec3(10.0f, 1.0f, 5.0f));
    model = glm::scale(model, glm::vec3(2.0f, 2.0f, 3.0f));
    shader.setMat4("model", model);
    glDrawArrays(GL_TRIANGLES, 0, 36);

    // Bike seat
    shader.setVec3("objectColor", 0.2f, 0.2f, 0.2f);
    model = glm::mat4(1.0f);
    model = glm::translate(model, glm::vec3(10.0f, 2.5f, 5.0f));
