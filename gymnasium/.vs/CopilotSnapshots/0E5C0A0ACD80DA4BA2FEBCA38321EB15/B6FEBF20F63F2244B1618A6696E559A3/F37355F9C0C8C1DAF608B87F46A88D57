    model = glm::translate(model, glm::vec3(5.0f, 1.0f, -8.0f));
    model = glm::scale(model, glm::vec3(4.0f, 0.5f, 1.5f));
    shader.setMat4("model", model);
    glDrawArrays(GL_TRIANGLES, 0, 36);

    // Bench supports
    for (int i = 0; i < 2; i++) {
        model = glm::mat4(1.0f);
        model = glm::translate(model, glm::vec3(5.0f + (i - 0.5f) * 3.0f, 0.5f, -8.0f));
