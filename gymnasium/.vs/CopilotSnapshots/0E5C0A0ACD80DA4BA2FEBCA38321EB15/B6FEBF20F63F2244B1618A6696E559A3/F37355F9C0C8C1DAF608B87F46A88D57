    shader.setVec3("objectColor", 0.7f, 0.8f, 0.85f);
    model = glm::mat4(1.0f);
    model = glm::translate(model, glm::vec3(0.0f, 4.0f, -14.8f));
    model = glm::scale(model, glm::vec3(15.0f, 6.0f, 0.1f));
    shader.setMat4("model", model);
    glDrawArrays(GL_TRIANGLES, 0, 36);

    // Plants
    shader.setVec3("objectColor", 0.3f, 0.6f, 0.3f);
    for (int i = 0; i < 3; i++) {
        model = glm::mat4(1.0f);
        model = glm::translate(model, glm::vec3(-18.0f, 1.5f, -10.0f + i * 10.0f));
        model = glm::scale(model, glm::vec3(0.8f, 3.0f, 0.8f));
        shader.setMat4("model", model);
        glDrawArrays(GL_TRIANGLES, 0, 36);
    }

    // Yoga mats
    shader.setVec3("objectColor", 0.7f, 0.2f, 0.8f);
    for (int i = 0; i < 3; i++) {
        model = glm::mat4(1.0f);
        model = glm::translate(model, glm::vec3(-8.0f + i * 3.0f, 0.15f, 10.0f));
        model = glm::scale(model, glm::vec3(1.8f, 0.05f, 5.0f));
        shader.setMat4("model", model);
        glDrawArrays(GL_TRIANGLES, 0, 36);
    }

    // Medicine balls
    shader.setVec3("objectColor", 0.2f, 0.5f, 0.8f);
    glBindVertexArray(cylinderVAO);
    for (int i = 0; i < 3; i++) {
        model = glm::mat4(1.0f);
        model = glm::translate(model, glm::vec3(15.0f, 0.5f, -5.0f + i * 2.0f));
        model = glm::scale(model, glm::vec3(1.0f, 1.0f, 1.0f));
        shader.setMat4("model", model);
        glDrawArrays(GL_TRIANGLE_STRIP, 0, 66);
    }
}